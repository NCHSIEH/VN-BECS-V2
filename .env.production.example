# =============================================================================
# VN-BECS-V2 PRODUCTION environment (pilot / UAT go-live)
# Copy to your deploy platform's secret store. DO NOT commit real values.
# =============================================================================

# Forces fail-closed behaviour: no demo login, no in-memory fallback, RBAC on.
NODE_ENV=production
VN_BECS_ENFORCE_API_RBAC=true

# Supabase (PostgreSQL) — clinical system of record. From Supabase Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Server-only service role key. Bypasses RLS for trusted server access and lets
# you lock down the public anon Data API. NEVER prefix NEXT_PUBLIC_, never expose.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Server-only: signs session tokens. MUST be >= 32 random chars and kept secret.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
VN_BECS_SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# NOTE: VN_BECS_ALLOW_DEMO_LOGIN / VN_BECS_ALLOW_FALLBACK have NO effect in
# production — both are hard-disabled when NODE_ENV=production.
