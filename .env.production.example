# =============================================================================
# VN-BECS-V2 PRODUCTION environment (pilot / UAT go-live)
# Copy to your deploy platform's secret store. DO NOT commit real values.
# =============================================================================

# Forces fail-closed behaviour: no demo login, no in-memory fallback, RBAC on.
NODE_ENV=production
VN_BECS_ENFORCE_API_RBAC=true

# Supabase (PostgreSQL) — clinical system of record. From Supabase Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Server-only service role key. Bypasses RLS for trusted server access and lets
# you lock down the public anon Data API. NEVER prefix NEXT_PUBLIC_, never expose.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Server-only: signs session tokens. MUST be >= 32 random chars and kept secret.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
VN_BECS_SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# NOTE: VN_BECS_ALLOW_DEMO_LOGIN / VN_BECS_ALLOW_FALLBACK have NO effect in
# production — both are hard-disabled when NODE_ENV=production.

# -----------------------------------------------------------------------------
# Tier B (OPTIONAL — leave UNSET until a real DB is wired and verified).
# When unset, the app behaves exactly as today (no atomic transaction, no DB-RLS).
# Both require migration 001 (multi-axis enums/columns + RLS policies) applied.
# -----------------------------------------------------------------------------
# Direct (owner) Postgres connection — enables the single-transaction atomic
# component+inventory+audit transition (RTM-STATE-03). e.g. Supabase "Connection
# string" (session/direct), NOT the pooled PgBouncer URL.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres
#
# Facility-scoped connection over a DB role WITHOUT BYPASSRLS — makes the
# facility RLS policies actually apply (RTM-AUTH-03). Create a dedicated role,
# e.g.  CREATE ROLE app_rls LOGIN PASSWORD '...';  (no BYPASSRLS, grant table
# privileges), then point this at it.
# SCOPED_DATABASE_URL=postgres://app_rls:PASSWORD@HOST:5432/postgres

# -----------------------------------------------------------------------------
# Offline sync hardening (OFF-01, OPTIONAL — leave unset to keep current behaviour).
# -----------------------------------------------------------------------------
# When set, every pushed offline event MUST carry a valid HMAC signature
# (client signs with the same secret) or it is rejected — prevents forged/tampered
# offline events. >= 32 random chars.
# VN_BECS_OFFLINE_SIGNING_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
#
# Offline events older than this (hours) are routed to manual review instead of
# auto-applied. Default 72.
# VN_BECS_OFFLINE_MAX_AGE_HOURS=72
