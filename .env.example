# =============================================================================
# VN-BBMS V2 Environment Variables
# =============================================================================

# --- PostgreSQL (Development: Docker Compose) ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=vnbbms
PG_USER=vnbbms
PG_PASSWORD=vnbbms_dev_2026

# --- PostgreSQL (Production: Supabase / Cloud) ---
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- PostgreSQL (Test) ---
# TEST_DATABASE_URL=postgresql://vnbbms:vnbbms_dev_2026@localhost:5432/vnbbms_test

# --- Firebase ---
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# --- Gemini API (V1 legacy) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Security / Identity (P0) ---
# Secret used to sign stateless session tokens (HMAC-SHA256). MUST be >= 32 chars.
# REQUIRED in production — startup/token-signing fails closed without it.
VN_BECS_SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars
# Force API RBAC even outside production (production always enforces).
VN_BECS_ENFORCE_API_RBAC=true
